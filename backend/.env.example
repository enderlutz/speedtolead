# Database — SQLite for local, PostgreSQL for production
# Local:  DATABASE_URL=sqlite:///./at_system_lite.db
# Supabase: DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
DATABASE_URL=sqlite:///./at_system_lite.db

# GHL - Cypress
GHL_API_KEY=
GHL_LOCATION_ID=

# GHL - Woodlands
GHL_API_KEY_2=
GHL_LOCATION_ID_2=

# Notifications
OWNER_GHL_CONTACT_ID=
OLGA_GHL_CONTACT_ID=

# Labels
GHL_LOCATION_1_LABEL=Cypress
GHL_LOCATION_2_LABEL=Woodlands

# URLs — update these after deploying frontend to Vercel
FRONTEND_URL=http://localhost:5173
PROPOSAL_BASE_URL=http://localhost:5173

# Google Maps
GOOGLE_MAPS_API_KEY=

# GHL Pipeline sync
GHL_PIPELINE_ID=
GHL_PIPELINE_ID_2=

# Server / CORS — set to your Vercel domain in production
PORT=8000
ALLOWED_ORIGINS=*
# Production example: ALLOWED_ORIGINS=https://at-system-lite.vercel.app,https://yourdomain.com
